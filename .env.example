# n8n Workflow Builder — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ─── n8n Instance ────────────────────────────────────────────────────────────
N8N_API_URL=http://100.80.13.56:5678
N8N_API_KEY=YOUR_N8N_API_KEY_HERE

# ─── n8n Built-in MCP Server (Runtime) ──────────────────────────────────────
# Get this from: n8n Settings > Instance-level MCP > Connection details
# Paste your personal MCP access token here.
N8N_MCP_TOKEN=REPLACE_WITH_YOUR_N8N_MCP_TOKEN

# ─── Optional: Alerting Credentials ─────────────────────────────────────────
# If you want build-time error notifications
SLACK_WEBHOOK_URL=
